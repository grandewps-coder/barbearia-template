---
import empresa from "../data/empresa.json";

import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import SectionTitle from "./ui/SectionTitle.astro";
---

<Section id="localizacao">

  <Container>

    <SectionTitle
      title="Venha conhecer a Barbearia Fernandes"
      subtitle="Estamos prontos para receber você com conforto, qualidade e atendimento personalizado."
    />

    <div class="mt-14 grid gap-10 lg:grid-cols-2">

      <!-- Informações -->

      <div class="flex flex-col justify-center rounded-3xl bg-neutral-100 p-10">

        <span class="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-amber-600">
          Localização
        </span>

        <h3 class="text-3xl font-black">

          Estamos em Justinópolis

        </h3>

        <p class="mt-5 leading-8 text-neutral-600">

          {empresa.endereco}<br />
          {empresa.bairro} — {empresa.cidade}

        </p>

        <div class="mt-10 space-y-5">

          <div class="flex items-center gap-4">

            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white shadow">

              📞

            </div>

            <div>

              <p class="font-semibold">

                Telefone

              </p>

              <p class="text-neutral-600">

                {empresa.telefone}

              </p>

            </div>

          </div>

          <div class="flex items-center gap-4">

            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white shadow">

              🕒

            </div>

            <div>

              <p class="font-semibold">

                Atendimento

              </p>

              <p class="text-neutral-600">

                Segunda a Sábado

              </p>

            </div>

          </div>

          <div class="flex items-center gap-4">

            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white shadow">

              📍

            </div>

            <div>

              <p class="font-semibold">

                Fácil acesso

              </p>

              <p class="text-neutral-600">

                Região central de Justinópolis

              </p>

            </div>

          </div>

        </div>

        <a
          href={empresa.maps}
          target="_blank"
          class="mt-10 inline-flex w-fit items-center gap-3 rounded-xl bg-black px-7 py-4 font-semibold text-white transition hover:scale-105"
        >

          Como chegar →

        </a>

      </div>

      <!-- Google Maps -->

      <div class="overflow-hidden rounded-3xl shadow-2xl">

        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3753.726709018561!2d-44.00862552477593!3d-19.80918138155221!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xa68e1be4fed159%3A0x7ce3ad8974cf38c2!2sBarbearia%20Fernandes!5e0!3m2!1spt-BR!2sbr!4v1784347184363!5m2!1spt-BR!2sbr"
          width="100%"
          height="600"
          style="border:0;"
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
        >
        </iframe>

      </div>

    </div>

  </Container>

</Section>