---
import servicos from "../data/servicos.json";

import Container from "./ui/Container.astro";
import Card from "./ui/Card.astro";
import Section from "./ui/Section.astro";
import SectionTitle from "./ui/SectionTitle.astro";
---

<Section id="servicos">

  <Container>

    <SectionTitle
      title="Nossos Serviços"
      subtitle="Cuidados masculinos com qualidade, técnica e atenção aos detalhes."
    />

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {
        servicos.map((servico, index) => (

          <Card class="group transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl">

            <div>

              <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-amber-100">

                <span class="text-3xl">

                  {
                    index === 0 ? "✂" :
                    index === 1 ? "✦" :
                    index === 2 ? "🪒" :
                    index === 3 ? "◉" :
                    "◆"
                  }

                </span>

              </div>

              <h3 class="mb-3 text-2xl font-bold">

                {servico.nome}

              </h3>

              <p class="mb-6 text-neutral-600 leading-relaxed">

                {servico.descricao}

              </p>

              <span class="font-semibold text-amber-700 transition group-hover:translate-x-1 inline-block">

                Atendimento Premium →

              </span>

            </div>

          </Card>

        ))
      }

    </div>

  </Container>

</Section>