---
import empresa from "../data/empresa.json";
import Container from "./ui/Container.astro";
---

<footer class="mt-20 border-t border-neutral-200 bg-neutral-950 py-14 text-white">

  <Container>

    <div class="grid gap-12 md:grid-cols-3">

      <!-- Empresa -->

      <div>

        <img
          src={empresa.logo}
          alt={empresa.nome}
          class="mb-5 h-16 w-auto"
        />

        <p class="text-neutral-400">

          Especialistas em cortes masculinos, barba e tendências.
          Atendimento personalizado em Justinópolis.

        </p>

      </div>

      <!-- Contato -->

      <div>

        <h3 class="mb-4 text-xl font-bold">

          Contato

        </h3>

        <ul class="space-y-3 text-neutral-400">

          <li>📞 {empresa.telefone}</li>

          <li>📍 {empresa.endereco}</li>

          <li>{empresa.bairro} - {empresa.cidade}</li>

          <li>
            <a
              href={empresa.instagram}
              target="_blank"
              class="hover:text-white"
            >
              Instagram
            </a>
          </li>

        </ul>

      </div>

      <!-- Agendamento -->

      <div>

        <h3 class="mb-4 text-xl font-bold">

          Agende seu horário

        </h3>

        <p class="mb-6 text-neutral-400">

          Clique no botão abaixo para agendar seu atendimento.

        </p>

        <a
          href={empresa.agendamento}
          target="_blank"
          class="inline-block rounded-xl bg-white px-6 py-3 font-semibold text-black transition hover:scale-105"
        >

          Agendar agora

        </a>

      </div>

    </div>

    <div class="mt-14 border-t border-neutral-800 pt-8 text-center text-sm text-neutral-500">

      © 2026 {empresa.nome}. Todos os direitos reservados.

    </div>

  </Container>

</footer>