---
import empresa from "../data/empresa.json";
import Container from "./ui/Container.astro";
---

<footer class="mt-20 border-t border-neutral-800 bg-neutral-950 text-white">

  <Container>

    <div class="grid gap-12 py-16 md:grid-cols-3">

      <!-- Empresa -->
      <div>

        <img
          src={empresa.logo}
          alt={empresa.nome}
          class="mb-5 h-16 w-auto"
        />

        <p class="leading-relaxed text-neutral-400">
          Especialistas em cortes masculinos, barba e tendências.
          Atendimento personalizado em Justinópolis, Ribeirão das Neves.
        </p>

      </div>

      <!-- Contato -->
      <div>

        <h3 class="mb-6 text-xl font-bold">
          Contato
        </h3>

        <ul class="space-y-4 text-neutral-400">

          <li class="flex items-center gap-3">
            📞
            <span>{empresa.telefone}</span>
          </li>

          <li class="flex items-center gap-3">
            📍
            <span>{empresa.endereco}</span>
          </li>

          <li class="flex items-center gap-3">
            🏙️
            <span>{empresa.bairro} - {empresa.cidade}</span>
          </li>

          <li>

            <a
              href={empresa.instagram}
              target="_blank"
              class="flex items-center gap-3 transition hover:text-amber-400"
            >

              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-5 w-5"
              >
                <path d="M7.75 2C4.57 2 2 4.57 2 7.75v8.5C2 19.43 4.57 22 7.75 22h8.5C19.43 22 22 19.43 22 16.25v-8.5C22 4.57 19.43 2 16.25 2h-8.5zm0 2h8.5A3.75 3.75 0 0120 7.75v8.5A3.75 3.75 0 0116.25 20h-8.5A3.75 3.75 0 014 16.25v-8.5A3.75 3.75 0 017.75 4zm8.75 1a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5zM12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z"/>
              </svg>

              Instagram

            </a>

          </li>

        </ul>

      </div>

      <!-- Agendamento -->
      <div>

        <h3 class="mb-6 text-xl font-bold">
          Agende seu horário
        </h3>

        <p class="mb-6 leading-relaxed text-neutral-400">
          Faça seu agendamento online e garanta um atendimento personalizado com horário reservado.
        </p>

        <a
          href={empresa.agendamento}
          target="_blank"
          class="inline-flex items-center rounded-xl bg-amber-500 px-6 py-3 font-semibold text-black transition duration-300 hover:scale-105 hover:bg-amber-400"
        >

          Agendar agora

        </a>

      </div>

    </div>

    <div class="border-t border-neutral-800 py-6 text-center">

      <p class="text-sm text-neutral-500">
        © 2026 {empresa.nome}. Todos os direitos reservados.
      </p>

      <p class="mt-2 text-xs text-neutral-600">
        Desenvolvido com Astro • Tailwind CSS
      </p>

    </div>

  </Container>

</footer>