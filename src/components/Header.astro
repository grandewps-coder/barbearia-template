---
import empresa from "../data/empresa.json";
import Button from "./ui/Button.astro";
import Container from "./ui/Container.astro";
---

<header class="absolute inset-x-0 top-0 z-50">

  <Container>

    <div class="flex h-20 items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">

        <img
          src={empresa.logo}
          alt={empresa.nome}
          class="h-12 md:h-14 w-auto"
        />

        <div class="hidden sm:block">

          <h2 class="text-lg font-bold text-white">
            {empresa.nome}
          </h2>

          <p class="text-sm text-neutral-300">
            ★★★★★ Atendimento Premium
          </p>

        </div>

      </a>

      <!-- Desktop -->

      <nav class="hidden lg:flex items-center gap-8 text-white">

        <a href="#top" class="hover:text-amber-300 transition">
          Início
        </a>

        <a href="#servicos" class="hover:text-amber-300 transition">
          Serviços
        </a>

        <a href="#sobre" class="hover:text-amber-300 transition">
          Sobre
        </a>

        <a href="#faq" class="hover:text-amber-300 transition">
          FAQ
        </a>

        <a href="#localizacao" class="hover:text-amber-300 transition">
          Localização
        </a>

      </nav>

      <div class="hidden md:block">

        <Button
          href={empresa.agendamento}
          texto="Agendar Horário"
          target="_blank"
        />

      </div>

      <!-- Botão Mobile -->

      <button
        id="menuButton"
        class="md:hidden rounded-xl bg-white p-3 shadow-lg"
      >

        ☰

      </button>

    </div>

  </Container>

</header>

<!-- Overlay -->

<div
  id="overlay"
  class="fixed inset-0 z-[90] hidden bg-black/60"
></div>

<!-- Menu -->

<aside
  id="mobileMenu"
  class="fixed right-0 top-0 z-[100] h-screen w-72 translate-x-full bg-neutral-950 p-8 text-white transition-transform duration-300"
>

  <div class="mb-10 flex items-center justify-between">

    <h2 class="text-xl font-bold">

      Menu

    </h2>

    <button
      id="closeMenu"
      class="text-3xl"
    >

      ✕

    </button>

  </div>

  <nav class="flex flex-col gap-6 text-lg">

    <a href="#top" class="mobile-link">
      Início
    </a>

    <a href="#servicos" class="mobile-link">
      Serviços
    </a>

    <a href="#sobre" class="mobile-link">
      Sobre
    </a>

    <a href="#faq" class="mobile-link">
      FAQ
    </a>

    <a href="#localizacao" class="mobile-link">
      Localização
    </a>

  </nav>

  <a
    href={empresa.agendamento}
    target="_blank"
    class="mt-10 inline-block rounded-xl bg-amber-500 px-6 py-4 font-bold text-black"
  >

    Agendar Horário

  </a>

</aside>

<script>

const menu=document.getElementById("mobileMenu");
const overlay=document.getElementById("overlay");

document.getElementById("menuButton")?.addEventListener("click",()=>{

menu.classList.remove("translate-x-full");

overlay.classList.remove("hidden");

});

function fechar(){

menu.classList.add("translate-x-full");

overlay.classList.add("hidden");

}

document.getElementById("closeMenu")?.addEventListener("click",fechar);

overlay?.addEventListener("click",fechar);

document.querySelectorAll(".mobile-link").forEach(link=>{

link.addEventListener("click",fechar);

});

</script>