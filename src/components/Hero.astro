---
import empresa from "../data/empresa.json";
import Button from "./ui/Button.astro";
---

<section
  
  class="relative flex min-h-screen items-center justify-center overflow-hidden pt-24"
>
>

  <!-- Imagem de fundo -->
  <img
    src="/images/hero.png"
    alt="Barbearia Fernandes"
    class="absolute inset-0 h-full w-full object-cover object-[0%] md:object-center"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/35 to-black/60"></div>

  <!-- Conteúdo -->
  <div class="relative z-10 mx-auto max-w-6xl px-6 text-center text-white">

    <span class="inline-block rounded-full border border-white/30 bg-white/10 px-5 py-2 text-sm backdrop-blur">
      {empresa.fundacao}
    </span>

    <h1 class="mt-8 max-w-4xl text-5xl font-black leading-tight tracking-tight md:text-7xl">

      {empresa.slogan}

    </h1>

    <p class="mx-auto mt-6 max-w-xl text-lg text-neutral-100">

      Fade Premium • Barboterapia • Platinado • Atendimento Personalizado

    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button
        href={empresa.agendamento}
        texto="Agendar Horário"
        target="_blank"
      />

      <Button
        href={empresa.maps}
        texto="Como chegar"
        target="_blank"
      />

    </div>

  </div>

</section>  