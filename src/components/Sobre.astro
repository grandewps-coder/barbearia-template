---
import empresa from "../data/empresa.json";

import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
---

<Section id="sobre">

  <Container>

    <div class="grid items-center gap-16 lg:grid-cols-2">

      <!-- FOTO -->

      <div class="relative flex justify-center">

      <div class="absolute h-[450px] w-[320px] rounded-[32px] bg-amber-100 -z-10 translate-x-6 translate-y-6"></div>

        <div class="relative overflow-hidden rounded-[32px] shadow-2xl">

          <img
            src={empresa.proprietarioFoto}
            alt={empresa.proprietario}
            class="h-[620px] w-full max-w-md object-cover"
          />

          <!-- Card flutuante -->

          <div class="absolute bottom-6 right-6 rounded-2xl border border-white/20 bg-black/45 px-6 py-5 text-white backdrop-blur-md shadow-xl">

            <p class="text-2xl font-black">
             ★★★★★

          </p>

           <p class="mt-1 text-sm uppercase tracking-wider text-white/70">
            Google

            
          </p>

          </div>

        </div>

      </div>

      <!-- TEXTO -->

      <div>

        <span class="rounded-full bg-amber-100 px-4 py-2 text-sm font-semibold text-amber-700">

          Desde 2016

        </span>

        <h2 class="mt-6 text-4xl font-black leading-tight md:text-5xl">

          Mais do que cortes.

          <br>

          Transformamos autoestima.

        </h2>

        <p class="mt-8 text-lg leading-8 text-neutral-600">

          {empresa.sobre}

        </p>

        <div class="mt-10 grid gap-5">

          <div class="flex items-center gap-4">

            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-amber-100 text-xl">

              ✂

            </div>

            <div>

              <h3 class="font-bold">

                Atendimento Personalizado

              </h3>

              <p class="text-neutral-600">

                Cada cliente recebe um corte pensado para seu estilo.

              </p>

            </div>

          </div>

          <div class="flex items-center gap-4">

            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-amber-100 text-xl">

              ★

            </div>

            <div>

              <h3 class="font-bold">

                Técnicas Modernas

              </h3>

              <p class="text-neutral-600">

                Fade, barba, platinado e tendências atuais.

              </p>

            </div>

          </div>

          <div class="flex items-center gap-4">

            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-amber-100 text-xl">

              ✔

            </div>

            <div>

              <h3 class="font-bold">

                Qualidade em cada detalhe

              </h3>

              <p class="text-neutral-600">

                Produtos profissionais e acabamento impecável.

              </p>

            </div>

          </div>

        </div>

        <div class="mt-12 rounded-3xl border border-neutral-200 bg-neutral-50 p-6">

          <p class="text-sm uppercase tracking-[0.2em] text-neutral-500">

            Responsável

          </p>

          <h3 class="mt-2 text-2xl font-black">

            {empresa.proprietario}

          </h3>

          <p class="mt-2 text-neutral-600">

            {empresa.experiencia}

          </p>

        </div>

      </div>

    </div>

  </Container>

</Section>